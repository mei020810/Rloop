        input_files=()
        for i in 1 2; do
            file="${base_dir}/${variety}-${i}-input_x800_${suffix}.sorted.bam"
            if [[ -f "$file" ]]; then
                input_files+=("$file")
            fi
        done
        
        if [[ ${#input_files[@]} -gt 0 ]]; then
            echo "合并input样本: ${input_files[*]}"
            samtools merge -@ 8 ${OUTPUT_DIR}/${variety}_input_${suffix}.merged.bam ${input_files[@]}
            samtools index -@ 8 ${OUTPUT_DIR}/${variety}_input_${suffix}.merged.bam
        fi
    done
}

