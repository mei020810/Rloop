#!/bin/bash
#只有基因的bed
GFF_FILE="/data/mshe/rloopData/Gmax_508_Wm82.a4.v1.gene.gff3"
ANNOTATION_DIR="/data/mshe/rloopData/annotation"
mkdir -p "$ANNOTATION_DIR"
out="${ANNOTATION_DIR}/genes.bed"
awk '$3=="gene" {
    # 1-based GFF -> BED start = start-1
    id="."
    n=split($9, a, ";")
    for(i=1;i<=n;i++){
        if(a[i] ~ /^ID=/){ split(a[i],b,"="); id=b[2]; break }
        if(a[i] ~ /^Name=/){ split(a[i],b,"="); id=b[2] } 
    }
    if(id=="" || id==".") id="gene"
    print $1, $4-1, $5, id, 0, $7
}' OFS="\t" "$GFF_FILE" > "$out"
echo "Done. 输出行数: $(wc -l < "$out")"
awk 'BEGIN { OFS="\t" }
{
    sub(/_scaffold.*/, "", $1);   # 删除_scaffold之后内容
    gsub(/\r/, "");               # 清除隐藏的\r
    $1=$1;                        
    print
}
'  "/data/mshe/rloopData/annotation/genes.bed" > "/data/mshe/rloopData/annotation/genes_fixed.bed"
  awk '$6=="+"' "/data/mshe/rloopData/annotation/genes_fixed.bed" > "/data/mshe/rloopData/annotation/genes_plus1.bed"
  awk '$6=="-"' "/data/mshe/rloopData/annotation/genes_fixed.bed" > "/data/mshe/rloopData/annotation/genes_minus1.bed"
# 生成基因间区域bed文件
samtools faidx Gmax_508_v4.0.fa
cut -f1 "/data/mshe/rloopData/Gmax_508_v4.0.fa.fai" > "/data/mshe/rloopData/chromosome_order.txt"
# 首先合并所有基因区域（包括sense和antisense）
cat "/data/mshe/rloopData/annotation/genes_plus1.bed" "/data/mshe/rloopData/annotation/genes_minus1.bed" | sort -k1,1 -k2,2n | bedtools sort -g "/data/mshe/rloopData/chromosome_order.txt" > "/data/mshe/rloopData/annotation/all_genes_combined_sorted1.bed"
# 用bedtools complement获取基因间区域，需要基因组fai文件来定义染色体边界，需要排序的bed文件
