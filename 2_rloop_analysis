#!/bin/bash

DEEPTOOLS_DIR="/data/mshe/rloopData/deeptools/four_panel"
BIGWIG_DIR="/data/mshe/rloopData/deeptools/bigwigs"
REGIONS_DIR="/data/mshe/rloopData/q0_01_macs3_results_full"
mkdir -p "$DEEPTOOLS_DIR"

# 使用HX3-IP的peak作为参考区域（重复性最好）
awk -v OFS='\t' '{print $1, $2-2000, $3+2000, $4, $5}' "${REGIONS_DIR}/HX3-1-IP_x800_bw2_q0_01_nomodel.macs3_summits.bed" > "${DEEPTOOLS_DIR}/HX3_reference_regions_2kb.bed"
REF_PEAKS="${DEEPTOOLS_DIR}/HX3_reference_regions_2kb.bed"

# 为每个品种创建四面板热图
for variety in HC22 HH43 HX3 Wm82 ZH13; do
    echo "处理品种: $variety"
    
    # 定义四个样本的bigWig文件
    declare -a bw_files=(
        "${BIGWIG_DIR}/${variety}-1-input_x800_full.bw"
        "${BIGWIG_DIR}/${variety}-2-input_x800_full.bw"
        "${BIGWIG_DIR}/${variety}-1-IP_x800_full.bw" 
        "${BIGWIG_DIR}/${variety}-2-IP_x800_full.bw"
    )
    
    # 样本标签
    declare -a sample_labels=(
        "${variety}-Input-Rep1"
        "${variety}-Input-Rep2" 
        "${variety}-IP-Rep1"
        "${variety}-IP-Rep2"
    )
    
    # 计算矩阵
    computeMatrix reference-point \
        --referencePoint center \
        -b 2000 -a 2000 \
        -R "$REF_PEAKS" \
        -S "${bw_files[@]}" \
        --missingDataAsZero \
	-p 10 \
        -o "${DEEPTOOLS_DIR}/${variety}_four_panel_matrix.gz" \
        --outFileNameMatrix "${DEEPTOOLS_DIR}/${variety}_four_panel_matrix.tab" \
        --outFileSortedRegions "${DEEPTOOLS_DIR}/${variety}_four_panel_regions.bed"
    
    # 检查矩阵是否成功生成
    if [ ! -f "${DEEPTOOLS_DIR}/${variety}_four_panel_matrix.gz" ]; then
        echo "错误: 矩阵生成失败 - ${variety}"
        continue
    fi

    # 绘制四面板热图
    plotHeatmap \
        -m "${DEEPTOOLS_DIR}/${variety}_four_panel_matrix.gz" \
        -o "${DEEPTOOLS_DIR}/${variety}_four_panel_heatmap.pdf" \
        --colorMap Blues \
        --whatToShow 'heatmap and colorbar' \
        --samplesLabel "${sample_labels[@]}" \
        --plotTitle "${variety} R-loop Signal" \
        --refPointLabel "Summit" \
        --legendLocation "upper-right" \
        --xAxisLabel "Distance from summit (bp)" \
        --yAxisLabel "" \
        --perGroup \
	--dpi 300
done

