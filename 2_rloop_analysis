            window50_ratio_ba=$(awk -v w=$window50_ba -v r2=$rep2_count 'BEGIN {printf "%.2f", w*100/r2}')
            window100_ratio_ba=$(awk -v w=$window100_ba -v r2=$rep2_count 'BEGIN {printf "%.2f", w*100/r2}')
        else
