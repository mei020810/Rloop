vim narrowpeak_classify_bed.sh
#!/bin/bash
set -euo pipefail
WCRLOOP_DIR="/data/mshe/rloopData/macs3_results_merge_wcRloop"
ANNOTATION_DIR="/data/mshe/rloopData/annotation"
OUTPUT_DIR="/data/mshe/rloopData/narrowpeak_gene_regions"
mkdir -p "$OUTPUT_DIR"
echo "=== 生成有R-loop peak的sense/antisense/intergenic基因区域BED==="
for variety in HC22 HH43 HX3 Wm82 ZH13; do
for type in IP input; do
    echo "处理品种: ${variety} ${type}"
WRLOOP_PEAKS="${WCRLOOP_DIR}/${variety}_${type}_x800_bw2_wRloop_nomodel.macs3_peaks.narrowPeak"
CRLOOP_PEAKS="${WCRLOOP_DIR}/${variety}_${type}_x800_bw2_cRloop_nomodel.macs3_peaks.narrowPeak"
    GENES_PLUS="${ANNOTATION_DIR}/genes_plus1.bed"    
    GENES_MINUS="${ANNOTATION_DIR}/genes_minus1.bed"
    INTERGENIC_BED="${ANNOTATION_DIR}/intergenic_regions1.bed"
    # Sense基因：有wRloop peak的正链基因 + 有cRloop peak的负链基因
    # 使用 -wa 保留基因注释的所有列（包括strand）
    bedtools intersect -a "$GENES_PLUS" -b "$WRLOOP_PEAKS" -wa -u > \
        "${OUTPUT_DIR}/${variety}_${type}_sense_genes_w.bed"
    bedtools intersect -a "$GENES_MINUS" -b "$CRLOOP_PEAKS" -wa -u > \
        "${OUTPUT_DIR}/${variety}_${type}_sense_genes_c.bed"
    cat "${OUTPUT_DIR}/${variety}_${type}_sense_genes_w.bed" \
        "${OUTPUT_DIR}/${variety}_${type}_sense_genes_c.bed" | \
        sort -k1,1 -k2,2n | uniq > \
        "${OUTPUT_DIR}/${variety}_${type}_sense_genes.bed"
    # Antisense基因：有wRloop peak的负链基因 + 有cRloop peak的正链基因  
    bedtools intersect -a "$GENES_MINUS" -b "$WRLOOP_PEAKS" -wa -u > \
        "${OUTPUT_DIR}/${variety}_${type}_antisense_genes_w.bed"
    bedtools intersect -a "$GENES_PLUS" -b "$CRLOOP_PEAKS" -wa -u > \
        "${OUTPUT_DIR}/${variety}_${type}_antisense_genes_c.bed"
    cat "${OUTPUT_DIR}/${variety}_${type}_antisense_genes_w.bed" \
        "${OUTPUT_DIR}/${variety}_${type}_antisense_genes_c.bed" | \
        sort -k1,1 -k2,2n | uniq > \
        "${OUTPUT_DIR}/${variety}_${type}_antisense_genes.bed"
    # Intergenic区域：有wRloop peak的intergenic区域 + 有cRloop peak的intergenic区域
    bedtools intersect -a "$INTERGENIC_BED" -b "$WRLOOP_PEAKS" -wa -u > \
        "${OUTPUT_DIR}/${variety}_${type}_intergenic_regions_w.bed"
    bedtools intersect -a "$INTERGENIC_BED" -b "$CRLOOP_PEAKS" -wa -u > \
        "${OUTPUT_DIR}/${variety}_${type}_intergenic_regions_c.bed"
    cat "${OUTPUT_DIR}/${variety}_${type}_intergenic_regions_w.bed" \
        "${OUTPUT_DIR}/${variety}_${type}_intergenic_regions_c.bed" | \
        sort -k1,1 -k2,2n | uniq > \
        "${OUTPUT_DIR}/${variety}_${type}_intergenic_regions.bed"
    sense_count=$(wc -l < "${OUTPUT_DIR}/${variety}_${type}_sense_genes.bed")
    antisense_count=$(wc -l < "${OUTPUT_DIR}/${variety}_${type}_antisense_genes.bed")
    intergenic_count=$(wc -l < "${OUTPUT_DIR}/${variety}_${type}_intergenic_regions.bed")
    echo "    Sense基因: $sense_count"
    echo "    Antisense基因: $antisense_count" 
    echo "    Intergenic区域: $intergenic_count"
    rm "${OUTPUT_DIR}/${variety}_${type}_sense_genes_w.bed" \
       "${OUTPUT_DIR}/${variety}_${type}_sense_genes_c.bed" \
       "${OUTPUT_DIR}/${variety}_${type}_antisense_genes_w.bed" \
       "${OUTPUT_DIR}/${variety}_${type}_antisense_genes_c.bed" \
       "${OUTPUT_DIR}/${variety}_${type}_intergenic_regions_w.bed" \
       "${OUTPUT_DIR}/${variety}_${type}_intergenic_regions_c.bed"
done
done
chmod u+x narrowpeak_classify_bed.sh
nohup ./narrowpeak_classify_bed.sh > narrowpeak_classify_bed.log 2>&1 &

