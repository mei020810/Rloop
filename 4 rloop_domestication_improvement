# ---- helper: read deepTools profile.tab (your wide format) ----
read_dt_profile_wide <- function(f) {
  x <- readLines(f, warn = FALSE)
  x <- x[nchar(x) > 0]

  # line2: bins 1..N
  bins_tok <- strsplit(trimws(x[2]), "\\s+")[[1]]
  bins <- as.integer(bins_tok[bins_tok != "bins"])

  # line3: sample group v1..vN
  v <- strsplit(trimws(x[3]), "\\s+")[[1]]
  sample <- v[1]
  group <- v[2]
  vals <- as.numeric(v[3:length(v)])

  if (length(vals) != length(bins)) {
    stop(sprintf("Length mismatch in %s: bins=%d vals=%d", f, length(bins), length(vals)))
  }
  list(bins=bins, sample=sample, group=group, vals=vals)
}

# ---- 1) random band ----
rand_list <- lapply(rand_files, read_dt_profile_wide)
bins <- rand_list[[1]]$bins
nb <- length(bins)
# collect random curves into matrix: [nrep x nbins]
rand_mat <- matrix(NA_real_, nrow=length(rand_list), ncol=nb)
for (i in seq_along(rand_list)) {
  if (!all(rand_list[[i]]$bins == bins)) stop("Bins inconsistent across random files.")
  rand_mat[i, ] <- rand_list[[i]]$vals
}

rand_mean <- colMeans(rand_mat, na.rm=TRUE)
rand_lo <- apply(rand_mat, 2, quantile, probs=0.025, na.rm=TRUE, names=FALSE)
rand_hi <- apply(rand_mat, 2, quantile, probs=0.975, na.rm=TRUE, names=FALSE)

# convert bins to bp axis (TSS ±2000, binSize 50)
binSize <- 50
up <- 2000
pos_bp <- -up + (bins - 0.5) * binSize

# ---- 2) fixed groups (domestication / improvement) ----
fx <- readLines(fixed_file, warn = FALSE)
fx <- fx[nchar(fx) > 0]

bins_tok2 <- strsplit(trimws(fx[2]), "\\s+")[[1]]
bins2 <- as.integer(bins_tok2[bins_tok2 != "bins"])
if (!all(bins2 == bins)) stop("Bins in HC22_dom_imp.profile.tab differ from random files.")

# from line3 onward: each line = sample group values...
lines <- fx[3:length(fx)]

# parse all lines
fixed_sample <- character(0)
fixed_group <- character(0)
fixed_vals <- list()

for (ln in lines) {
  v <- strsplit(trimws(ln), "\\s+")[[1]]
  if (length(v) < (2 + nb)) next
  fixed_sample <- c(fixed_sample, v[1])
  fixed_group  <- c(fixed_group,  v[2])
  fixed_vals[[length(fixed_vals) + 1]] <- as.numeric(v[3:length(v)])
}
if (length(fixed_vals) == 0) stop("No data lines parsed from HC22_dom_imp.profile.tab.")

# If multiple samples exist, pick the first sample (or set target_sample manually)
